<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/keyboard_height"
    android:orientation="vertical"
    android:background="#0000FF"
    android:padding="4dp">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:columnCount="4">

        <!-- Row 1: 1, 2, 3, @ -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="1"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="2"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="3"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="@"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 2: 4, 5, 6, # -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="4"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="5"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="6"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="#"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 3: 7, 8, 9, $ -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="7"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="8"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="9"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="$"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 4: 0, *, +, - -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="0"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="*"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="-"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 5: /, =, %, . -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="/"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="="
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="%"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="."
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 6: !, ?, &, ( -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="!"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="?"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="&amp;"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="("
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <!-- Row 7: ), _, [, ] -->
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text=")"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="_"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="["
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:text="]"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            android:padding="12dp" />

    </GridLayout>
</LinearLayout>